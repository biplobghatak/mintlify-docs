{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Outpulse",
  "colors": {
    "primary": "#3eb8ff",
    "light": "#3eb8ff",
    "dark": "#2a9fd6"
  },
  "appearance": {
    "default": "system"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@outpulse.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://outpulse.app/dashboard"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "getting-started/quickstart",
              "getting-started/how-it-works",
              "getting-started/connect-x-account"
            ]
          },
          {
            "group": "Core features",
            "pages": [
              "core/icp",
              "core/tone-profile",
              "core/monitors",
              "core/inbox",
              "core/drafts",
              "core/posting-modes",
              "core/queue",
              "core/people",
              "core/analytics",
              "core/follow-ups"
            ]
          },
          {
            "group": "Workspaces & team",
            "pages": [
              "team/workspaces",
              "team/roles"
            ]
          },
          {
            "group": "Settings",
            "pages": [
              "settings/connections",
              "settings/schedule",
              "settings/notifications"
            ]
          }
        ]
      },
      {
        "tab": "Credits & billing",
        "groups": [
          {
            "group": "Credits",
            "pages": [
              "credits/how-credits-work",
              "credits/credit-costs",
              "credits/buying-credits",
              "credits/auto-topup",
              "credits/roi"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://outpulse.app/blog",
          "icon": "newspaper"
        },
        {
          "anchor": "X (Twitter)",
          "href": "https://x.com/outpulseapp",
          "icon": "x-twitter"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/outpulseapp"
    }
  }
}
